<Window x:Class="FluentTune.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:conv="clr-namespace:FluentTune.Converters"
    xmlns:ctl="clr-namespace:FluentTune.Controls"
    Title="FluentTune"
    Width="442"
    SizeToContent="Height"
    MinHeight="0"
    WindowStyle="None"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    ShowActivated="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    AllowsTransparency="True"
    Background="Transparent"
    Opacity="0">

    <Window.Resources>
        <conv:PlayPauseSymbolConverter x:Key="PlayPause" />
    </Window.Resources>

    <Grid x:Name="Root">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="RootTransform" Y="0" />
        </Grid.RenderTransform>

        <!-- Glass card (fully custom shape => no rectangular box behind the rounded corners) -->
        <Border x:Name="Card" Margin="24" CornerRadius="16" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.55" Color="#000000" />
            </Border.Effect>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                    <GradientStop Color="#E61E2130" Offset="0" />
                    <GradientStop Color="#E6141620" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#45FFFFFF" Offset="0" />
                    <GradientStop Color="#0EFFFFFF" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <!-- Album-colour glow (adapts to the cover) -->
                <Border CornerRadius="16" Background="{Binding GlowBrush}" />

                <!-- Liquid-glass sheen -->
                <Border CornerRadius="16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                            <GradientStop Color="#1FFFFFFF" Offset="0" />
                            <GradientStop Color="#08FFFFFF" Offset="0.5" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Content -->
                <Grid Margin="18,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Album art with an accent ring that follows the cover -->
                    <Border Grid.Column="0" Width="78" Height="78" CornerRadius="12"
                            BorderThickness="1.5" BorderBrush="{Binding AccentBrush}" VerticalAlignment="Top">
                        <Grid>
                            <Border CornerRadius="11" Background="#22FFFFFF">
                                <ui:SymbolIcon Symbol="MusicNote124" FontSize="30" Opacity="0.45"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border x:Name="ArtBorder" CornerRadius="11">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White" TextTrimming="CharacterEllipsis" Margin="0,0,24,0" />
                        <TextBlock Text="{Binding Artist}" FontSize="12.5" Opacity="0.68"
                                   Foreground="White" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />

                        <!-- Progress + seek -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding PositionText}" FontSize="11" Opacity="0.6"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ctl:WaveProgressBar x:Name="Wave" Grid.Column="1" Height="24" Margin="2,0"
                                                 VerticalAlignment="Center"
                                                 Value="{Binding PositionSeconds, Mode=OneWay}"
                                                 Maximum="{Binding DurationSeconds}"
                                                 Fill="{Binding AccentBrush}" IsActive="{Binding IsPlaying}" />
                            <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontSize="11" Opacity="0.6"
                                       Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </Grid>

                        <!-- Transport controls + volume -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <ui:Button Appearance="Secondary" Padding="8" Margin="0,0,8,0"
                                           Click="Previous_Click" ToolTip="Anterior">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Previous24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                                <Border Width="44" Height="34" CornerRadius="8" Margin="0,0,8,0"
                                        Background="{Binding AccentBrush}" Cursor="Hand"
                                        MouseLeftButtonUp="PlayPauseBorder_Click" ToolTip="Reproducir / Pausar">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="1" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.85" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <ui:SymbolIcon Symbol="{Binding IsPlaying, Converter={StaticResource PlayPause}}"
                                                   FontSize="18" Foreground="{Binding AccentForeground}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ui:Button Appearance="Secondary" Padding="8" Click="Next_Click" ToolTip="Siguiente">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon Symbol="Next24" />
                                    </ui:Button.Icon>
                                </ui:Button>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Speaker224" FontSize="16" Opacity="0.7" Foreground="White"
                                               Margin="0,0,6,0" VerticalAlignment="Center" />
                                <Slider x:Name="VolumeSlider" Width="92" Minimum="0" Maximum="1"
                                        IsMoveToPointEnabled="True" VerticalAlignment="Center"
                                        ValueChanged="Volume_Changed" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Close button -->
                <ui:Button x:Name="CloseButton" Appearance="Transparent" Padding="4"
                           Width="28" Height="28" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0"
                           Click="Close_Click" ToolTip="Cerrar">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Dismiss24" />
                    </ui:Button.Icon>
                </ui:Button>
            </Grid>
        </Border>
    </Grid>
</Window>
